PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
DEFAULT_ORGANIZATION_ID=org-demo-001
CORS_ORIGIN=http://localhost:5173

# Must match your S3 bucket and DynamoDB table region (e.g. us-east-2)
AWS_REGION=us-east-2
AWS_ACCESS_KEY=your-access-key
AWS_SECRET_KEY=your-secret-key
AWS_S3_BUCKET=crossover-image-processing
AWS_DYNAMODB_TABLE=crossover-image-processing
DYNAMODB_AUTO_CREATE=true
